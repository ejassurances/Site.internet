NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://www.ej-assurances.fr

# Legacy projects can use this instead of NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Resend (emails transactionnels) ─────────────────────────────────────
# Créez votre compte sur https://resend.com
# Récupérez votre clé API dans Settings > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse expéditeur — DOIT correspondre à un domaine vérifié dans Resend
RESEND_FROM_EMAIL=EJ Partners Assurances <contact@ej-assurances.fr>

# Adresse de réception des notifications internes (nouvelles demandes de contact)
RESEND_ADMIN_EMAIL=contact@ej-assurances.fr

# ── OpenAI (module IA IaGO) ────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Workspace (intégration CRM) ───────────────────────────────
# Créez un projet OAuth 2.0 dans Google Cloud Console
# Scopes recommandés : openid email profile gmail.readonly drive.readonly calendar.readonly
GOOGLE_WORKSPACE_CLIENT_ID=your-google-client-id
GOOGLE_WORKSPACE_CLIENT_SECRET=your-google-client-secret
GOOGLE_WORKSPACE_REDIRECT_URI=https://www.ej-assurances.fr/api/google/callback
GOOGLE_WORKSPACE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/drive.readonly https://www.googleapis.com/auth/calendar.readonly
GOOGLE_WORKSPACE_DOMAIN=ej-assurances.fr

# ── Google Drive (upload documents, dossiers clients & partenaires) ──────
# Identifiants OAuth avec le scope https://www.googleapis.com/auth/drive
# (lecture + écriture). Utilisés par /api/upload-drive, /api/drive-files
# et la création automatique des dossiers partenaires.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
# Dossier Drive racine où sont créés les dossiers partenaires.
# À défaut de GOOGLE_DRIVE_PARTENAIRES_FOLDER_ID, GOOGLE_DRIVE_ROOT_FOLDER_ID est utilisé.
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_PARTENAIRES_FOLDER_ID=
