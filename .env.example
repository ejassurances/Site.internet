NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://www.ej-assurances.fr

# Legacy projects can use this instead of NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Resend (emails transactionnels) ─────────────────────────────────────
# Créez votre compte sur https://resend.com
# Récupérez votre clé API dans Settings > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse expéditeur — DOIT correspondre à un domaine vérifié dans Resend
RESEND_FROM_EMAIL=EJ Partners Assurances <contact@ej-assurances.fr>

# Adresse de réception des notifications internes (nouvelles demandes de contact)
RESEND_ADMIN_EMAIL=contact@ej-assurances.fr

# ── OpenAI (module IA IaGO) ────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
