---
interface Props {
  quote: string;
  author: string;
}

const { quote, author } = Astro.props;
---

<figure class="rounded-2xl bg-white p-6 shadow-sm border border-slate-100">
  <!-- Placeholder photo : remplacer par une vraie photo (carrée, 96x96px) avec autorisation du témoin -->
  <div class="flex items-center gap-4">
    <div class="h-12 w-12 flex-shrink-0 rounded-full bg-brand-100 border border-gold-300" aria-hidden="true"></div>
    <figcaption class="text-sm font-semibold text-slate-700">{author}</figcaption>
  </div>
  <blockquote class="mt-4 text-slate-600 italic leading-relaxed">"{quote}"</blockquote>
</figure>
