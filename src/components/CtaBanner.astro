---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Prendre un rendez-vous gratuit',
  subtitle = 'En ligne, par téléphone ou à domicile — sans engagement, réponse sous 24-48h.',
} = Astro.props;
---

<section class="bg-brand-900 text-white">
  <div class="mx-auto max-w-6xl px-4 py-12 text-center lg:px-8">
    <h2 class="text-2xl font-bold sm:text-3xl">{title}</h2>
    <p class="mt-3 text-brand-100">{subtitle}</p>
    <a
      href="/contact#rendez-vous"
      class="mt-6 inline-flex items-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-brand-800 shadow-lg hover:bg-brand-50 transition-colors"
    >
      Prendre rendez-vous (en ligne, par téléphone ou à domicile)
    </a>
  </div>
</section>
