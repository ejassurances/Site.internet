---
import { cabinet } from '../data/cabinet.js';

const situations = [
  { href: '/coparentalite', label: 'Coparentalité' },
  { href: '/familles-recomposees', label: 'Familles recomposées' },
  { href: '/communaute-lgbt', label: 'Communauté LGBT' },
];

const solutions = [
  { href: '/assurance-emprunteur', label: 'Assurance emprunteur' },
  { href: '/prevoyance', label: 'Prévoyance' },
  { href: '/transmission', label: 'Transmission' },
];

const simpleNavItems = [
  { href: '/associations', label: 'Associations' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-brand-100">
  <div class="mx-auto max-w-6xl flex items-center justify-between gap-4 px-4 py-3 lg:px-8">
    <a href="/" aria-label="Retour à l'accueil EJ Partners Assurances" class="flex items-center gap-3 text-brand-900">
      <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-900 font-serif text-sm font-bold text-white shadow-sm" aria-hidden="true">
        EJ
      </span>
      <span class="flex flex-col leading-tight">
        <span class="font-serif text-lg font-bold tracking-wide">EJ Partners</span>
        <span class="text-xs font-semibold uppercase tracking-wider text-gold-600">Assurances</span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-6 text-sm font-medium text-slate-700">
      <div class="group relative">
        <button
          type="button"
          class:list={[
            'flex items-center gap-1 hover:text-brand-700 transition-colors',
            situations.some((item) => currentPath.startsWith(item.href)) && 'text-brand-800 font-semibold',
          ]}
        >
          Vos situations
          <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="invisible absolute left-0 top-full z-10 w-64 rounded-xl border border-slate-200 bg-white p-2 opacity-0 shadow-lg transition-all group-hover:visible group-hover:opacity-100">
          {situations.map((item) => (
            <a href={item.href} class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-50 hover:text-brand-800">
              {item.label}
            </a>
          ))}
        </div>
      </div>

      <div class="group relative">
        <button
          type="button"
          class:list={[
            'flex items-center gap-1 hover:text-brand-700 transition-colors',
            solutions.some((item) => currentPath.startsWith(item.href)) && 'text-brand-800 font-semibold',
          ]}
        >
          Nos solutions
          <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="invisible absolute left-0 top-full z-10 w-64 rounded-xl border border-slate-200 bg-white p-2 opacity-0 shadow-lg transition-all group-hover:visible group-hover:opacity-100">
          {solutions.map((item) => (
            <a href={item.href} class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-brand-50 hover:text-brand-800">
              {item.label}
            </a>
          ))}
        </div>
      </div>

      {simpleNavItems.map((item) => (
        <a
          href={item.href}
          class:list={['hover:text-brand-700 transition-colors', currentPath.startsWith(item.href) && 'text-brand-800 font-semibold']}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/connexion"
        class="hidden sm:inline-flex items-center rounded-full border border-brand-300 px-4 py-2 text-sm font-semibold text-brand-700 hover:bg-brand-50 transition-colors"
      >
        Espace client
      </a>
      <a
        href="/contact#rendez-vous"
        class="inline-flex items-center rounded-full bg-brand-700 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-800 transition-colors"
      >
        Prendre rendez-vous
      </a>
    </div>
  </div>

  <nav class="lg:hidden flex gap-4 overflow-x-auto px-4 pb-3 text-sm font-medium text-slate-700">
    {situations.map((item) => (
      <a href={item.href} class="whitespace-nowrap hover:text-brand-700">{item.label}</a>
    ))}
    {solutions.map((item) => (
      <a href={item.href} class="whitespace-nowrap hover:text-brand-700">{item.label}</a>
    ))}
    {simpleNavItems.map((item) => (
      <a href={item.href} class="whitespace-nowrap hover:text-brand-700">{item.label}</a>
    ))}
  </nav>
</header>
