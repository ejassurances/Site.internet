---
const nav = [
  { href: '/', label: 'Accueil' },
  { href: '/assurance-emprunteur', label: 'Assurance emprunteur' },
  { href: '/prevoyance', label: 'Prévoyance' },
  { href: '/transmission', label: 'Transmission' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="bg-white/95 backdrop-blur border-b border-slate-200 sticky top-0 z-50 shadow-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="font-semibold text-slate-900 text-lg">
      EJ Partners Assurances
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm text-slate-700">
      {nav.map((item) => (
        <a href={item.href} class="transition hover:text-slate-900">{item.label}</a>
      ))}
      <a href="https://moncompte.ej-assurances.fr" target="_blank" rel="noopener noreferrer" class="rounded-full border border-brand-500 bg-brand-500 px-4 py-2 text-white transition hover:bg-brand-600">
        Espace client
      </a>
    </nav>
    <div class="md:hidden">
      <a href="https://moncompte.ej-assurances.fr" target="_blank" rel="noopener noreferrer" class="rounded-full border border-brand-500 bg-brand-500 px-4 py-2 text-white text-xs tracking-wide">
        Espace client
      </a>
    </div>
  </div>
</header>
