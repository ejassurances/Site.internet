---
import { cabinet } from '../data/cabinet.js';

const navItems = [
  { href: '/', label: 'Accueil' },
  { href: '/assurance-emprunteur', label: 'Assurance emprunteur' },
  { href: '/prevoyance', label: 'Prévoyance' },
  { href: '/transmission', label: 'Transmission' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-rose-100">
  <div class="mx-auto max-w-6xl flex items-center justify-between gap-4 px-4 py-3 lg:px-8">
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-violet-800">
      <span class="inline-block h-3 w-3 rounded-full bg-gradient-to-br from-rose-400 via-amber-400 to-violet-500" aria-hidden="true"></span>
      EJ Partners Assurances
    </a>

    <nav class="hidden lg:flex items-center gap-6 text-sm font-medium text-slate-700">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'hover:text-violet-700 transition-colors',
            (item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href)) &&
              'text-violet-800 font-semibold',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={cabinet.espaceClientUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center rounded-full border border-violet-300 px-4 py-2 text-sm font-semibold text-violet-700 hover:bg-violet-50 transition-colors"
      >
        Espace client
      </a>
      <a
        href="/contact"
        class="inline-flex items-center rounded-full bg-violet-700 px-4 py-2 text-sm font-semibold text-white hover:bg-violet-800 transition-colors"
      >
        Prendre rendez-vous
      </a>
    </div>
  </div>

  <nav class="lg:hidden flex gap-4 overflow-x-auto px-4 pb-3 text-sm font-medium text-slate-700">
    {navItems.map((item) => (
      <a href={item.href} class="whitespace-nowrap hover:text-violet-700">{item.label}</a>
    ))}
  </nav>
</header>
