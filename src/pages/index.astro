---
import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Accueil" description="Courtier spécialisé en assurance coparentalité et familles recomposées à Eaubonne.">
  <Header />
  <main class="mx-auto max-w-7xl px-6 py-10 lg:py-16">
    <section class="grid gap-10 lg:grid-cols-[1.2fr,0.8fr] lg:items-center">
      <div class="space-y-6">
        <p class="inline-flex rounded-full bg-softgreen-100 px-4 py-1 text-sm font-semibold text-softgreen-800">Courtier dédié aux familles séparées et recomposées</p>
        <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">Accompagner votre famille recomposée avec une assurance sereine</h1>
        <p class="max-w-2xl text-lg leading-8 text-slate-700">EJ Partners Assurances propose un accompagnement personnalisé pour les familles en coparentalité, afin de protéger votre crédit, sécuriser l’avenir des enfants et organiser une transmission équitable.</p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="/contact" class="inline-flex items-center justify-center rounded-full bg-brand-600 px-7 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-500/20 transition hover:bg-brand-700">Prendre un rendez-vous gratuit</a>
          <a href="#expertises" class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-7 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-100">Découvrir nos expertises</a>
        </div>
      </div>
      <div class="rounded-3xl bg-gradient-to-br from-slate-100 via-white to-softgreen-50 p-6 shadow-xl shadow-slate-200/80">
        <div class="flex h-full min-h-[320px] flex-col justify-between rounded-3xl bg-white p-6">
          <div class="rounded-3xl bg-slate-100 p-8 text-center text-slate-500">Visuel famille/protection 1200×800</div>
          <div class="mt-6 space-y-4 text-left">
            <p class="text-lg font-semibold text-slate-900">Accompagnement sur mesure</p>
            <p class="text-slate-600">Rendez-vous en ligne, par téléphone ou à domicile, sans engagement en agence.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="expertises" class="mt-16 space-y-8">
      <div class="grid gap-6 md:grid-cols-3">
        <article class="rounded-3xl bg-white p-8 shadow-sm shadow-slate-200/60">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-600">Assurance emprunteur</p>
          <h2 class="mt-4 text-2xl font-semibold text-slate-900">Co-emprunteurs séparés</h2>
          <p class="mt-3 text-slate-600">Protégez un prêt immobilier en situation de coparentalité ou de famille recomposée.</p>
          <a href="/assurance-emprunteur" class="mt-6 inline-flex text-sm font-semibold text-brand-600 hover:text-brand-700">Voir cette expertise →</a>
        </article>
        <article class="rounded-3xl bg-white p-8 shadow-sm shadow-slate-200/60">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-softgreen-600">Prévoyance</p>
          <h2 class="mt-4 text-2xl font-semibold text-slate-900">Sécuriser les revenus</h2>
          <p class="mt-3 text-slate-600">Garantir le quotidien des enfants en cas de décès, invalidité ou arrêt de travail.</p>
          <a href="/prevoyance" class="mt-6 inline-flex text-sm font-semibold text-brand-600 hover:text-brand-700">Voir cette expertise →</a>
        </article>
        <article class="rounded-3xl bg-white p-8 shadow-sm shadow-slate-200/60">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-700">Transmission</p>
          <h2 class="mt-4 text-2xl font-semibold text-slate-900">Organiser l’héritage</h2>
          <p class="mt-3 text-slate-600">Construire un partage transparent entre enfants de différentes unions.</p>
          <a href="/transmission" class="mt-6 inline-flex text-sm font-semibold text-brand-600 hover:text-brand-700">Voir cette expertise →</a>
        </article>
      </div>
    </section>

    <section class="mt-16 rounded-[2rem] bg-brand-600 px-8 py-12 text-white shadow-2xl shadow-brand-500/20">
      <div class="grid gap-8 lg:grid-cols-[1.2fr,0.8fr] lg:items-center">
        <div>
          <p class="text-sm uppercase tracking-[0.24em] text-brand-200">Réassurance</p>
          <h2 class="mt-4 text-3xl font-semibold">Accompagnement personnalisé, sans engagement</h2>
          <p class="mt-4 max-w-2xl text-lg leading-8 text-brand-100">Nos clients reçoivent une réponse sous 24-48h. Un expert dédié analyse votre situation familiale, juridique et émotionnelle pour proposer des solutions claires.</p>
        </div>
        <div class="space-y-4 rounded-3xl bg-white/10 p-6 text-sm text-brand-100">
          <div class="rounded-3xl bg-white/15 p-5">
            <p class="font-semibold">Expertise</p>
            <p>Familles séparées / recomposées, situation juridique complexe.</p>
          </div>
          <div class="rounded-3xl bg-white/15 p-5">
            <p class="font-semibold">Disponibilité</p>
            <p>Rendez-vous en ligne, par téléphone ou à domicile.</p>
          </div>
          <div class="rounded-3xl bg-white/15 p-5">
            <p class="font-semibold">Réponse rapide</p>
            <p>Proposition personnalisée sous 48h.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Reassurance from '../components/Reassurance.astro';

const situations = [
  {
    href: '/coparentalite',
    title: 'Coparentalité',
    description: "Protégez vos enfants entre deux foyers, sécurisez revenus et crédit quelle que soit la situation du couple.",
  },
  {
    href: '/familles-recomposees',
    title: 'Familles recomposées',
    description: "Protégez votre nouveau conjoint et les enfants de chaque union, organisez une transmission équitable.",
  },
  {
    href: '/communaute-lgbt',
    title: 'Communauté LGBT',
    description: "Protégez votre partenaire et le parent non légalement reconnu, évitez la sur-taxation des couples non mariés.",
  },
];

const expertises = [
  {
    href: '/assurance-emprunteur',
    title: 'Assurance emprunteur',
    description:
      "Protégez votre crédit immobilier en tant que co-emprunteurs, quel que soit votre statut juridique : mariage, Pacs ou concubinage.",
  },
  {
    href: '/prevoyance',
    title: 'Prévoyance',
    description:
      "Protégez votre partenaire et chacun de vos enfants, quelle que soit la manière dont votre famille s'est construite.",
  },
  {
    href: '/transmission',
    title: 'Transmission',
    description:
      "Organisez une transmission de patrimoine équitable pour votre partenaire survivant et tous vos enfants.",
  },
];
---

<Layout
  title="EJ Partners Assurances | Familles modernes"
  description="Premier cabinet de courtage à adapter l'assurance et la prévoyance à l'évolution des familles modernes : emprunteur, prévoyance, transmission."
>
  <!-- Hero -->
  <section class="bg-brand-50">
    <div class="mx-auto max-w-6xl px-4 py-16 lg:flex lg:items-center lg:gap-12 lg:px-8 lg:py-24">
      <div class="lg:w-1/2">
        <p class="text-sm font-semibold uppercase tracking-wider text-gold-600">Le premier cabinet pensé pour les familles modernes</p>
        <h1 class="mt-3 text-3xl font-extrabold leading-tight text-brand-900 sm:text-4xl lg:text-5xl">
          L'assurance qui s'adapte à <span class="text-brand-700">l'évolution des familles</span>
        </h1>
        <p class="mt-5 text-lg text-slate-600">
          Couples mariés, pacsés ou en concubinage, familles recomposées, monoparentales ou construites par
          adoption, PMA ou GPA : EJ Partners Assurances est le premier cabinet de courtage à concevoir des
          solutions d'assurance emprunteur, de prévoyance et de transmission réellement adaptées à la diversité
          des familles d'aujourd'hui.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/contact#rendez-vous"
            class="inline-flex items-center rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-800"
          >
            Prendre rendez-vous (en ligne, par téléphone ou à domicile)
          </a>
          <a
            href="/a-propos"
            class="inline-flex items-center rounded-full border border-brand-300 px-6 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-50"
          >
            Découvrir notre approche
          </a>
        </div>
      </div>
      <div class="mt-12 lg:mt-0 lg:w-1/2">
        <!-- Placeholder visuel : photo de famille, format paysage 800x600px -->
        <div class="aspect-[4/3] w-full rounded-3xl bg-brand-100 shadow-inner"></div>
      </div>
    </div>
  </section>

  <!-- Réassurance -->
  <section class="px-4 py-10 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <Reassurance />
    </div>
  </section>

  <!-- Vos situations -->
  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-2xl font-bold text-brand-900 sm:text-3xl">Vos situations</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-slate-600">
        L'assurance et la protection qui s'adaptent à votre famille, quelle que soit la façon dont elle s'est
        construite.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        {situations.map((item) => (
          <a
            href={item.href}
            class="flex flex-col rounded-2xl border border-slate-200 p-6 hover:border-brand-300 hover:shadow-md transition-all"
          >
            <h3 class="text-lg font-bold text-brand-800">{item.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600">{item.description}</p>
            <span class="mt-4 text-sm font-semibold text-brand-700">En savoir plus →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Expertises -->
  <section class="bg-slate-50 px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-2xl font-bold text-brand-900 sm:text-3xl">Nos 3 solutions</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-slate-600">
        Des solutions construites autour des réalités juridiques et humaines des familles modernes, là où les
        assureurs classiques proposent encore des contrats standards souvent inadaptés.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        {expertises.map((item) => (
          <a
            href={item.href}
            class="flex flex-col rounded-2xl border border-slate-200 p-6 hover:border-brand-300 hover:shadow-md transition-all"
          >
            <h3 class="text-lg font-bold text-brand-800">{item.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600">{item.description}</p>
            <span class="mt-4 text-sm font-semibold text-brand-700">En savoir plus →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Pourquoi nous -->
  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-2xl font-bold text-brand-900 sm:text-3xl">Pourquoi un courtier pensé pour les familles modernes ?</h2>
      <p class="mt-4 text-slate-600 leading-relaxed">
        Les contrats d'assurance standards ne tiennent pas toujours compte des réalités juridiques des couples non
        mariés, des parents non biologiques ou des familles recomposées. Nous connaissons ces situations dans le
        détail et construisons avec vous des solutions réellement adaptées à votre famille, telle qu'elle est.
      </p>
    </div>
  </section>

  <CtaBanner />
</Layout>
