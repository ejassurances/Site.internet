---
import Layout from '../layouts/Layout.astro';
import { cabinet } from '../data/cabinet.js';

const accessProfiles = [
  {
    title: 'Client',
    description: 'Suivre vos projets, contrats, documents et messages avec le cabinet.',
  },
  {
    title: 'Courtier / admin',
    description: 'Piloter les clients, projets, contrats, documents et demandes du cabinet.',
  },
  {
    title: 'Mandataire',
    description: 'Accéder à vos clients, projets, commissions, documents et conformité.',
  },
  {
    title: 'Prescripteur',
    description: 'Déposer un prospect et suivre les transmissions envoyées au cabinet.',
  },
];
---

<Layout
  title="Connexion à votre espace | EJ Partners Assurances"
  description="Accès unique aux espaces client, courtier, mandataire et prescripteur EJ Partners Assurances."
>
  <section class="bg-brand-50 px-4 py-14 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-gold-600">Accès sécurisé</p>
      <h1 class="mt-3 text-3xl font-extrabold text-slate-900 sm:text-4xl">Connexion à votre espace</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        Un point d'entrée unique pour les clients, courtiers, mandataires et prescripteurs EJ Partners Assurances.
      </p>
    </div>
  </section>

  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.95fr,1.05fr]">
      <form id="login-form" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-900">Se connecter</h2>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">
          Saisissez vos identifiants pour accéder à votre espace EJ Partners Assurances. Votre rôle détermine
          automatiquement l'espace affiché après connexion.
        </p>

        <div class="mt-6">
          <label for="email" class="block text-sm font-semibold text-slate-700">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            placeholder="vous@exemple.fr"
            required
            class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 placeholder-slate-400 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
          />
        </div>

        <div class="mt-5">
          <label for="password" class="block text-sm font-semibold text-slate-700">Mot de passe</label>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            placeholder="Votre mot de passe"
            required
            class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 placeholder-slate-400 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
          />
        </div>

        <p id="login-status" class="mt-5 hidden rounded-lg px-4 py-3 text-sm" aria-live="polite"></p>

        <button
          id="login-submit"
          type="submit"
          class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-800 disabled:cursor-not-allowed disabled:bg-slate-400"
        >
          Accéder à mon espace
        </button>

        <div class="mt-5 flex flex-wrap items-center justify-between gap-3 text-sm">
          <a href="/contact#rendez-vous" class="font-semibold text-brand-700 hover:underline">
            Demander un accès
          </a>
          <a href={`mailto:${cabinet.emails.serviceClient}`} class="font-semibold text-brand-700 hover:underline">
            Mot de passe oublié
          </a>
        </div>
      </form>

      <div>
        <h2 class="text-2xl font-bold text-slate-900">Espaces disponibles</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {accessProfiles.map((profile) => (
            <article class="rounded-2xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-brand-800">{profile.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{profile.description}</p>
            </article>
          ))}
        </div>

        <div class="mt-6 rounded-2xl bg-slate-50 p-5 text-sm leading-relaxed text-slate-600">
          <strong class="text-slate-900">Confidentialité :</strong> chaque utilisateur accède uniquement aux
          dossiers et documents liés à son rôle. Les accès clients, mandataires et prescripteurs sont séparés
          dans l'espace sécurisé.
        </div>
      </div>
    </div>
  </section>

  <script type="module" is:inline>
    import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm';

    const supabase = createClient(
      'https://huneukcmqaftwhidyegi.supabase.co',
      'sb_publishable_Z02td2yUOY7XR1Xnra6umw_Sdb_yziw',
      {
        auth: {
          persistSession: true,
          autoRefreshToken: true,
          detectSessionInUrl: true,
        },
      },
    );

    const form = document.querySelector('#login-form');
    const submitButton = document.querySelector('#login-submit');
    const statusBox = document.querySelector('#login-status');

    const setStatus = (message, type = 'info') => {
      statusBox.textContent = message;
      statusBox.classList.remove('hidden', 'bg-red-50', 'text-red-700', 'bg-brand-50', 'text-brand-800');
      statusBox.classList.add(type === 'error' ? 'bg-red-50' : 'bg-brand-50');
      statusBox.classList.add(type === 'error' ? 'text-red-700' : 'text-brand-800');
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const email = String(formData.get('email') || '').trim();
      const password = String(formData.get('password') || '');

      if (!email || !password) {
        setStatus('Merci de renseigner votre email et votre mot de passe.', 'error');
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = 'Connexion en cours...';
      setStatus('Vérification de vos identifiants...');

      const { data, error } = await supabase.auth.signInWithPassword({ email, password });

      if (error || !data?.user) {
        submitButton.disabled = false;
        submitButton.textContent = 'Accéder à mon espace';
        setStatus('Connexion impossible. Vérifiez votre email et votre mot de passe.', 'error');
        return;
      }

      const { data: profile } = await supabase
        .from('profiles')
        .select('role, full_name')
        .eq('id', data.user.id)
        .maybeSingle();

      if (profile?.role) {
        window.localStorage.setItem('ej_profile_role', profile.role);
        window.localStorage.setItem('ej_profile_name', profile.full_name || data.user.email || '');
      }

      setStatus('Connexion réussie. Ouverture de votre espace...');
      window.location.assign('/espace');
    });
  </script>
</Layout>
