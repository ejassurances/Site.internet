---
import Layout from '../layouts/Layout.astro';
import Reassurance from '../components/Reassurance.astro';
import { cabinet } from '../data/cabinet.js';
---

<Layout
  title="Contact et rendez-vous — EJ Partners Assurances"
  description="Prenez rendez-vous avec EJ Partners Assurances, courtier dédié aux familles LGBT à Eaubonne : en ligne, par téléphone ou à domicile, du lundi au vendredi."
>
  <section class="bg-brand-50 px-4 py-14 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-3xl font-extrabold text-slate-900 sm:text-4xl">Prendre rendez-vous</h1>
      <p class="mt-4 text-lg text-slate-600">En ligne, par téléphone ou à domicile — sur rendez-vous uniquement.</p>
    </div>
  </section>

  <section class="px-4 py-10 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <Reassurance />
    </div>
  </section>

  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-2">
      <!-- Formulaire de contact.
           Remplacer l'action ci-dessous par votre endpoint Formspree (cabinet.formspreeEndpoint
           dans src/data/cabinet.js), ou par une intégration Netlify Forms
           (ajouter data-netlify="true" + name="contact" si le site est déployé sur Netlify). -->
      <form
        action={cabinet.formspreeEndpoint}
        method="POST"
        class="flex flex-col gap-5 rounded-2xl border border-slate-200 p-6"
      >
        <div>
          <label for="nom" class="block text-sm font-semibold text-slate-700">Nom et prénom *</label>
          <input
            id="nom"
            name="nom"
            type="text"
            required
            class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-brand-500 focus:outline-none"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-slate-700">Email *</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-brand-500 focus:outline-none"
          />
        </div>

        <div>
          <label for="telephone" class="block text-sm font-semibold text-slate-700">Téléphone *</label>
          <input
            id="telephone"
            name="telephone"
            type="tel"
            required
            class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-brand-500 focus:outline-none"
          />
        </div>

        <div>
          <label for="besoin" class="block text-sm font-semibold text-slate-700">Votre besoin *</label>
          <select
            id="besoin"
            name="besoin"
            required
            class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-brand-500 focus:outline-none"
          >
            <option value="">Sélectionnez une option</option>
            <option value="assurance-emprunteur">Assurance emprunteur</option>
            <option value="prevoyance">Prévoyance</option>
            <option value="transmission">Transmission de patrimoine</option>
            <option value="autre">Autre demande</option>
          </select>
        </div>

        <div>
          <span class="block text-sm font-semibold text-slate-700">Type de rendez-vous souhaité *</span>
          <div class="mt-2 flex flex-col gap-2 sm:flex-row sm:gap-6">
            <label class="flex items-center gap-2 text-sm text-slate-600">
              <input type="radio" name="type_rdv" value="en_ligne" required class="text-brand-600" />
              En ligne
            </label>
            <label class="flex items-center gap-2 text-sm text-slate-600">
              <input type="radio" name="type_rdv" value="telephone" required class="text-brand-600" />
              Par téléphone
            </label>
            <label class="flex items-center gap-2 text-sm text-slate-600">
              <input type="radio" name="type_rdv" value="domicile" required class="text-brand-600" />
              À domicile
            </label>
          </div>
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-slate-700">Message (optionnel)</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-brand-500 focus:outline-none"
          ></textarea>
        </div>

        <label class="flex items-start gap-3 text-sm text-slate-600">
          <input type="checkbox" name="consentement_rgpd" required class="mt-1 text-brand-600" />
          <span>
            J'accepte que mes données soient utilisées par EJ Partners Assurances dans le cadre du traitement de
            ma demande, conformément à la
            <a href="/confidentialite" class="text-brand-700 underline">politique de confidentialité</a>. *
          </span>
        </label>

        <button
          type="submit"
          class="mt-2 inline-flex items-center justify-center rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-800"
        >
          Envoyer ma demande de rendez-vous
        </button>
      </form>

      <div class="flex flex-col gap-6">
        <div class="rounded-2xl border border-slate-200 p-6">
          <h2 class="text-lg font-bold text-slate-900">Nos coordonnées</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-600">
            <li><strong class="text-slate-800">Cabinet :</strong> {cabinet.nom}</li>
            <li><strong class="text-slate-800">Adresse :</strong> {cabinet.adresse}</li>
            <li><strong class="text-slate-800">Téléphone :</strong> <a href={cabinet.telephoneHref} class="text-brand-700 hover:underline">{cabinet.telephone}</a></li>
            <li><strong class="text-slate-800">Email :</strong> <a href={`mailto:${cabinet.emails.cabinet}`} class="text-brand-700 hover:underline">{cabinet.emails.cabinet}</a></li>
            <li><strong class="text-slate-800">Horaires :</strong> {cabinet.horaires}</li>
          </ul>
        </div>

        <div class="rounded-2xl border border-slate-200 p-6">
          <h2 class="text-lg font-bold text-slate-900">Autres contacts</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-600">
            <li><strong class="text-slate-800">Service client :</strong> <a href={`mailto:${cabinet.emails.serviceClient}`} class="text-brand-700 hover:underline">{cabinet.emails.serviceClient}</a></li>
            <li><strong class="text-slate-800">Sinistre :</strong> <a href={`mailto:${cabinet.emails.sinistre}`} class="text-brand-700 hover:underline">{cabinet.emails.sinistre}</a></li>
            <li><strong class="text-slate-800">RGPD / conformité :</strong> <a href={`mailto:${cabinet.emails.conformite}`} class="text-brand-700 hover:underline">{cabinet.emails.conformite}</a></li>
            <li><strong class="text-slate-800">Devenir prescripteur :</strong> <a href={`mailto:${cabinet.emails.prescripteur}`} class="text-brand-700 hover:underline">{cabinet.emails.prescripteur}</a></li>
            <li><strong class="text-slate-800">Recrutement :</strong> <a href={`mailto:${cabinet.emails.recrutement}`} class="text-brand-700 hover:underline">{cabinet.emails.recrutement}</a></li>
            <li>
              <strong class="text-slate-800">Espace client / prescripteur :</strong>
              <a href={cabinet.espaceClientUrl} target="_blank" rel="noopener noreferrer" class="text-brand-700 hover:underline">
                moncompte.ej-assurances.fr
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
