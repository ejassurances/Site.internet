---
import Layout from '../layouts/Layout.astro';

const roleSpaces = [
  {
    role: 'admin',
    title: 'Espace courtier admin',
    intro: 'Pilotage global du cabinet EJ Partners Assurances.',
    stats: [
      ['Clients actifs', 'À connecter'],
      ['Projets ouverts', 'À connecter'],
      ['Documents à traiter', 'À connecter'],
    ],
    modules: [
      'Gestion des clients',
      'Gestion des projets',
      'Gestion des contrats',
      'Gestion des documents',
      'Gestion des mandataires',
      'Gestion des prescripteurs',
      'Suivi des demandes',
      'Paramètres cabinet',
    ],
  },
  {
    role: 'courtier',
    title: 'Espace courtier',
    intro: 'Suivi opérationnel des dossiers clients et demandes entrantes.',
    stats: [
      ['Clients suivis', 'À connecter'],
      ['Contrats', 'À connecter'],
      ['Messages', 'À connecter'],
    ],
    modules: ['Clients', 'Projets', 'Contrats', 'Documents', 'Demandes', 'Messages'],
  },
  {
    role: 'client',
    title: 'Espace client',
    intro: 'Votre espace personnel pour suivre vos projets et documents.',
    stats: [
      ['Projets', 'À connecter'],
      ['Contrats', 'À connecter'],
      ['Documents', 'À connecter'],
    ],
    modules: ['Mes informations', 'Mes projets', 'Mes contrats', 'Mes documents', 'Dépôt de documents', 'Messages'],
  },
  {
    role: 'mandataire',
    title: 'Espace mandataire',
    intro: 'Votre activité commerciale, vos dossiers et votre conformité.',
    stats: [
      ['Clients', 'À connecter'],
      ['Projets', 'À connecter'],
      ['Commissions', 'À connecter'],
    ],
    modules: ['Mes clients', 'Mes projets', 'Mes commissions', 'Mes documents', 'Mon profil conformité'],
  },
  {
    role: 'prescripteur',
    title: 'Espace prescripteur',
    intro: 'Transmission et suivi des prospects confiés au cabinet.',
    stats: [
      ['Prospects transmis', 'À connecter'],
      ['En cours', 'À connecter'],
      ['Historique', 'À connecter'],
    ],
    modules: ['Déposer un prospect', 'Suivi des prospects transmis', 'Historique', 'Documents / convention'],
  },
];
---

<Layout
  title="Votre espace | EJ Partners Assurances"
  description="Espace sécurisé EJ Partners Assurances pour clients, courtiers, mandataires et prescripteurs."
>
  <section class="bg-brand-50 px-4 py-14 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-gold-600">Espace sécurisé</p>
      <h1 id="space-title" class="mt-3 text-3xl font-extrabold text-slate-900 sm:text-4xl">
        Ouverture de votre espace
      </h1>
      <p id="space-subtitle" class="mt-4 max-w-2xl text-lg text-slate-600">
        Vérification de votre session en cours.
      </p>
    </div>
  </section>

  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div id="space-alert" class="rounded-2xl border border-slate-200 bg-white p-6 text-sm leading-relaxed text-slate-600 shadow-sm">
        Chargement de votre profil...
      </div>

      <div id="space-content" class="mt-8 hidden">
        {roleSpaces.map((space) => (
          <section class="space-panel hidden" data-role={space.role}>
            <div class="grid gap-4 md:grid-cols-3">
              {space.stats.map(([label, value]) => (
                <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                  <p class="text-sm font-semibold text-slate-500">{label}</p>
                  <p class="mt-2 text-xl font-extrabold text-brand-800">{value}</p>
                </div>
              ))}
            </div>

            <div class="mt-8 grid gap-8 lg:grid-cols-[0.85fr,1.15fr]">
              <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <p class="text-sm font-semibold uppercase tracking-wider text-gold-600">Tableau de bord</p>
                <h2 class="mt-2 text-2xl font-bold text-slate-900">{space.title}</h2>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">{space.intro}</p>
                <div class="mt-6 rounded-xl bg-brand-50 p-4 text-sm leading-relaxed text-brand-900">
                  Connexion Supabase active. Les prochaines données affichées ici viendront des tables clients,
                  projects, contracts, documents, messages et referrals.
                </div>
              </article>

              <div class="grid gap-4 sm:grid-cols-2">
                {space.modules.map((module) => (
                  <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <h3 class="font-bold text-brand-800">{module}</h3>
                    <p class="mt-2 text-sm leading-relaxed text-slate-600">
                      Module prêt pour la V1. Les données seront branchées progressivement avec les droits du rôle.
                    </p>
                  </article>
                ))}
              </div>
            </div>
          </section>
        ))}

        <button
          id="logout-button"
          type="button"
          class="mt-8 inline-flex items-center justify-center rounded-full border border-brand-700 px-6 py-3 text-sm font-semibold text-brand-700 hover:bg-brand-50"
        >
          Se déconnecter
        </button>
      </div>
    </div>
  </section>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabase = createClient(
      'https://huneukcmqaftwhidyegi.supabase.co',
      'sb_publishable_Z02td2yUOY7XR1Xnra6umw_Sdb_yziw',
      {
        auth: {
          persistSession: true,
          autoRefreshToken: true,
          detectSessionInUrl: true,
        },
      },
    );

    const title = document.querySelector('#space-title');
    const subtitle = document.querySelector('#space-subtitle');
    const alertBox = document.querySelector('#space-alert');
    const content = document.querySelector('#space-content');
    const logoutButton = document.querySelector('#logout-button');
    const roleLabels = {
      admin: 'courtier admin',
      courtier: 'courtier',
      client: 'client',
      mandataire: 'mandataire',
      prescripteur: 'prescripteur',
    };

    const showError = (message) => {
      alertBox.textContent = message;
      alertBox.className = 'rounded-2xl border border-red-100 bg-red-50 p-6 text-sm leading-relaxed text-red-700 shadow-sm';
    };

    const { data: sessionData } = await supabase.auth.getSession();
    const session = sessionData?.session;

    if (!session?.user) {
      showError('Votre session n’est pas active. Vous allez être redirigé vers la page de connexion.');
      window.setTimeout(() => window.location.assign('/connexion'), 1200);
    } else {
      const { data: profile } = await supabase
        .from('profiles')
        .select('role, full_name')
        .eq('id', session.user.id)
        .maybeSingle();

      const storedRole = window.localStorage.getItem('ej_profile_role');
      const role = profile?.role || storedRole || 'client';
      const fullName = profile?.full_name || window.localStorage.getItem('ej_profile_name') || session.user.email;
      const matchingPanel = document.querySelector(`.space-panel[data-role="${role}"]`);

      title.textContent = `Bonjour ${fullName || ''}`.trim();
      subtitle.textContent = `Vous êtes connecté à votre espace ${roleLabels[role] || role}.`;
      alertBox.textContent = 'Connexion confirmée. Les modules de votre espace sont prêts à être reliés aux données Supabase.';
      alertBox.className = 'rounded-2xl border border-brand-100 bg-brand-50 p-6 text-sm leading-relaxed text-brand-800 shadow-sm';
      content.classList.remove('hidden');
      matchingPanel?.classList.remove('hidden');
    }

    logoutButton?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.localStorage.removeItem('ej_profile_role');
      window.localStorage.removeItem('ej_profile_name');
      window.location.assign('/connexion');
    });
  </script>
</Layout>
