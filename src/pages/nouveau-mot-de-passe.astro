---
import Layout from '../layouts/Layout.astro';

const siteName = 'EJ Partners Assurances';
---

<Layout
  title={`Nouveau mot de passe | ${siteName}`}
  description="Définir un nouveau mot de passe pour votre espace EJ Partners Assurances."
>
  <section class="bg-brand-50 px-4 py-14 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-gold-600">Accès sécurisé</p>
      <h1 class="mt-3 text-3xl font-extrabold text-slate-900 sm:text-4xl">Nouveau mot de passe</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        Définissez un nouveau mot de passe pour accéder à votre espace.
      </p>
    </div>
  </section>

  <section class="px-4 py-12 lg:px-8">
    <form
      id="update-password-form"
      method="post"
      action="/nouveau-mot-de-passe"
      class="mx-auto max-w-xl rounded-2xl border border-slate-200 bg-white p-6 shadow-sm"
    >
      <h2 class="text-2xl font-bold text-slate-900">Créer un nouveau mot de passe</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-600">
        Le lien reçu par email ouvre une session temporaire sécurisée. Choisissez un mot de passe robuste, puis
        reconnectez-vous.
      </p>

      <div class="mt-6">
        <label for="password" class="block text-sm font-semibold text-slate-700">Nouveau mot de passe</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="new-password"
          minlength="8"
          required
          class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 placeholder-slate-400 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
        />
      </div>

      <div class="mt-5">
        <label for="password-confirm" class="block text-sm font-semibold text-slate-700">
          Confirmer le mot de passe
        </label>
        <input
          id="password-confirm"
          name="password-confirm"
          type="password"
          autocomplete="new-password"
          minlength="8"
          required
          class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 placeholder-slate-400 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
        />
      </div>

      <p id="password-status" class="mt-5 rounded-lg bg-brand-50 px-4 py-3 text-sm text-brand-800" aria-live="polite">
        Vérification du lien de réinitialisation...
      </p>

      <button
        id="password-submit"
        type="submit"
        disabled
        class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-800 disabled:cursor-not-allowed disabled:bg-slate-400"
      >
        En attente du lien sécurisé...
      </button>
    </form>
  </section>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabase = createClient(
      'https://huneukcmqaftwhidyegi.supabase.co',
      'sb_publishable_Z02td2yUOY7XR1Xnra6umw_Sdb_yziw',
      {
        auth: {
          persistSession: true,
          autoRefreshToken: true,
          detectSessionInUrl: true,
        },
      },
    );

    const form = document.querySelector('#update-password-form');
    const submitButton = document.querySelector('#password-submit');
    const statusBox = document.querySelector('#password-status');

    const setStatus = (message, type = 'info') => {
      statusBox.textContent = message;
      statusBox.classList.remove('bg-red-50', 'text-red-700', 'bg-brand-50', 'text-brand-800');
      statusBox.classList.add(type === 'error' ? 'bg-red-50' : 'bg-brand-50');
      statusBox.classList.add(type === 'error' ? 'text-red-700' : 'text-brand-800');
    };

    const enableForm = () => {
      submitButton.disabled = false;
      submitButton.textContent = 'Modifier mon mot de passe';
      setStatus('Lien vérifié. Vous pouvez définir votre nouveau mot de passe.');
    };

    supabase.auth.onAuthStateChange((event) => {
      if (event === 'PASSWORD_RECOVERY' || event === 'SIGNED_IN') {
        enableForm();
      }
    });

    const { data: sessionData } = await supabase.auth.getSession();
    if (sessionData?.session?.user) {
      enableForm();
    } else {
      setStatus(
        "Aucune session de réinitialisation active. Ouvrez cette page depuis le lien reçu par email.",
        'error',
      );
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const password = String(formData.get('password') || '');
      const passwordConfirm = String(formData.get('password-confirm') || '');

      if (password.length < 8) {
        setStatus('Le mot de passe doit contenir au moins 8 caractères.', 'error');
        return;
      }

      if (password !== passwordConfirm) {
        setStatus('Les deux mots de passe ne correspondent pas.', 'error');
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = 'Modification en cours...';

      const { error } = await supabase.auth.updateUser({ password });

      if (error) {
        submitButton.disabled = false;
        submitButton.textContent = 'Modifier mon mot de passe';
        setStatus('Impossible de modifier le mot de passe. Le lien est peut-être expiré.', 'error');
        return;
      }

      await supabase.auth.signOut();
      setStatus('Mot de passe modifié. Redirection vers la connexion...');
      window.setTimeout(() => window.location.assign('/connexion'), 1200);
    });
  </script>
</Layout>
