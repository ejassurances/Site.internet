---
const pages = [
  '/',
  '/assurance-emprunteur',
  '/prevoyance',
  '/transmission',
  '/a-propos',
  '/contact',
  '/mentions-legales',
  '/confidentialite',
  '/informations-courtier',
];
const siteUrl = 'https://ej-partners-assurances.fr';
---
---
<xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {pages.map((page) => (
    <url>
      <loc>{siteUrl + page}</loc>
    </url>
  ))}
</urlset>
