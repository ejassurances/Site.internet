---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Faq from '../components/Faq.astro';
import Testimonial from '../components/Testimonial.astro';

const faqItems = [
  {
    question: 'Que se passe-t-il pour notre assurance emprunteur en cas de séparation ?',
    answer:
      "Nous vous accompagnons pour adapter ou désolidariser le contrat lors d'un rachat de soulte ou d'une séparation, afin que la couverture de chaque ex-conjoint reste cohérente avec la nouvelle répartition du crédit ou du logement.",
  },
  {
    question: 'Comment bien désigner les bénéficiaires quand on est parents séparés ?',
    answer:
      "Nous vous aidons à rédiger des clauses bénéficiaires précises pour que vos enfants restent protégés quelle que soit l'évolution de votre situation conjugale, indépendamment de la garde ou de la pension alimentaire en cours.",
  },
  {
    question: 'La pension alimentaire est-elle prise en compte dans la prévoyance ?',
    answer:
      "Oui. Nous dimensionnons les garanties décès, invalidité et arrêt de travail en tenant compte de vos obligations envers vos enfants, pour que la pension alimentaire ou la contribution à leur entretien soit maintenue en cas de coup dur.",
  },
];
---

<Layout
  title="Assurance coparentalité | EJ Partners Assurances"
  description="Assurance et prévoyance pour parents séparés ou coparents : protégez vos enfants entre deux foyers, sécurisez vos revenus et votre crédit immobilier."
>
  <section class="bg-brand-50 px-4 py-14 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-3xl font-extrabold text-slate-900 sm:text-4xl">Coparentalité</h1>
      <p class="mt-4 text-lg text-slate-600">
        L'assurance et la protection qui s'adaptent à votre famille — même lorsque vos enfants vivent entre deux
        foyers.
      </p>
    </div>
  </section>

  <!-- Situation concrète -->
  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-slate-900">Une situation que nous connaissons bien</h2>
      <p class="mt-4 leading-relaxed text-slate-600">
        Camille et Antoine se sont séparés il y a deux ans. Ils élèvent ensemble leurs deux enfants en garde
        alternée. Camille a gardé le crédit de l'appartement familial seule, tandis qu'Antoine verse une
        contribution à l'entretien des enfants. Tous les deux s'interrogent : en cas de décès ou d'incapacité de
        l'un d'eux, les enfants resteraient-ils protégés financièrement dans les deux foyers ?
      </p>
    </div>
  </section>

  <!-- Défis -->
  <section class="bg-slate-50 px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-slate-900">Les défis de la coparentalité</h2>
      <ul class="mt-4 space-y-3 text-slate-600">
        <li>— Protéger les enfants quel que soit le foyer dans lequel ils se trouvent.</li>
        <li>— Sécuriser un crédit immobilier porté par un seul ex-conjoint après la séparation.</li>
        <li>— Maintenir la pension alimentaire ou la contribution à l'entretien en cas de coup dur.</li>
        <li>— Désigner les bons bénéficiaires, sans ambiguïté, malgré l'évolution de la situation conjugale.</li>
      </ul>
    </div>
  </section>

  <!-- Comment la protection s'adapte -->
  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-slate-900">Comment notre protection s'adapte</h2>
      <p class="mt-4 leading-relaxed text-slate-600">
        Nous revoyons avec chaque parent la répartition de l'assurance emprunteur lors d'un rachat de soulte ou
        d'une désolidarisation de crédit. Nous rédigeons des clauses bénéficiaires de prévoyance qui désignent
        nommément vos enfants, dans chacun des deux foyers, et nous dimensionnons les garanties pour que la
        pension alimentaire ou la contribution à l'entretien soit maintenue en cas de décès, d'invalidité ou
        d'arrêt de travail.
      </p>
    </div>
  </section>

  <!-- Bénéfice -->
  <section class="bg-slate-50 px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-slate-900">Le bénéfice pour vous</h2>
      <ul class="mt-4 space-y-3 text-slate-600">
        <li>— Des enfants protégés financièrement, dans les deux foyers.</li>
        <li>— Un crédit immobilier sécurisé, même après une séparation.</li>
        <li>— Une tranquillité d'esprit pour chaque parent, sans tension entre ex-conjoints.</li>
      </ul>
    </div>
  </section>

  <!-- Témoignage -->
  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Ils nous font confiance</h2>
      <Testimonial
        quote="Après notre séparation, on ne savait pas comment réorganiser nos assurances sans se retrouver l'un contre l'autre. EJ Partners nous a accompagnés tous les deux, séparément, pour protéger nos enfants en priorité."
        author="Camille, maman coparente"
      />
    </div>
  </section>

  <!-- FAQ -->
  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Questions fréquentes</h2>
      <Faq items={faqItems} />
    </div>
  </section>

  <CtaBanner />
</Layout>
