---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Faq from '../components/Faq.astro';

const faqItems = [
  {
    question: "Qu'est-ce que la coparentalité et la pluriparentalité ?",
    answer:
      "La coparentalité désigne le choix d'élever un enfant ensemble sans être en couple (deux amis, un couple et un tiers donneur impliqué, etc.). La pluriparentalité concerne les configurations à plus de deux parents ou figures parentales. Le droit français protège encore mal ces situations, notamment le statut du parent social.",
  },
  {
    question: "Comment protéger un parent social qui n'a pas de lien de filiation reconnu ?",
    answer:
      "Par une désignation nominative dans les clauses bénéficiaires de prévoyance et d'assurance-vie : le parent social peut être protégé financièrement et désigné pour subvenir aux besoins de l'enfant, indépendamment de la reconnaissance légale du lien de filiation.",
  },
  {
    question: "Une assurance peut-elle s'adapter à plus de deux parents ou coparents ?",
    answer:
      "Oui. Nous structurons les clauses bénéficiaires et la répartition des contrats pour refléter l'organisation réelle de votre famille, qu'elle compte deux, trois ou plus de figures parentales.",
  },
];
---

<Layout
  title="Coparentalité et parent social | EJ Partners Assurances"
  description="Assurance et prévoyance pour la coparentalité et la protection du parent social, là où le droit classique protège encore mal ces familles."
>
  <section class="bg-brand-50 px-4 py-14 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-3xl font-extrabold text-slate-900 sm:text-4xl">Coparentalité & parent social</h1>
      <p class="mt-4 text-lg text-slate-600">
        Protégez chaque parent et chaque enfant, quelle que soit l'organisation de votre famille.
      </p>
    </div>
  </section>

  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-slate-900">Un vide juridique que nous comblons</h2>
      <p class="mt-4 leading-relaxed text-slate-600">
        Coparentalité, pluriparentalité, parent social non reconnu légalement : la loi française protège encore
        mal ces configurations familiales, qu'elles concernent des couples de même sexe, des couples hétérosexuels
        ou des amis qui choisissent d'élever un enfant ensemble sans être en couple.
      </p>
      <p class="mt-4 leading-relaxed text-slate-600">
        EJ Partners Assurances construit des solutions de prévoyance, d'assurance-vie et de transmission qui
        comblent ce vide : désignation nominative de chaque parent ou coparent comme bénéficiaire, répartition
        équitable entre tous les enfants du foyer, quelle que soit leur situation de filiation.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-2xl font-bold text-slate-900">Nos solutions</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <a href="/prevoyance" class="flex flex-col rounded-2xl bg-white p-6 shadow-sm border border-slate-100 hover:border-brand-300 transition-colors">
          <h3 class="font-bold text-brand-800">Prévoyance</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">Désignez chaque parent ou coparent comme bénéficiaire, sans attendre la reconnaissance légale du lien de filiation.</p>
        </a>
        <a href="/transmission" class="flex flex-col rounded-2xl bg-white p-6 shadow-sm border border-slate-100 hover:border-brand-300 transition-colors">
          <h3 class="font-bold text-brand-800">Transmission</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">Organisez une transmission équitable entre tous les enfants du foyer, quelle que soit leur filiation.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Questions fréquentes</h2>
      <Faq items={faqItems} />
    </div>
  </section>

  <CtaBanner />
</Layout>
